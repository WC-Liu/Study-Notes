   "source": [
    "#直接导入\n",
    "import math  # 导入Python自带的数学模块\n",
    "\n",
    "print(math.sqrt(16))  # 开平方 → 4\n",
    "print(math.pi)        # 圆周率\n",
    "\n",
    "#重新起名（方便）\n",
    "import math as m\n",
    "\n",
    "print(m.sqrt(25))  # 5\n",
    "\n",
    "#只导入需要的功能（最常用）\n",
    "from math import sqrt, pi\n",
    "\n",
    "print(sqrt(9))  # 3\n",
    "print(pi)"
   ],
